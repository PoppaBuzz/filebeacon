<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    tools:context=".MainActivity">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#0A1628">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="20dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical"
            android:background="#0A1628">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/icon"
                android:contentDescription="FileBeacon logo"
                android:scaleType="fitCenter"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/appNameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FileBeacon"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your files. Always within reach."
                    android:textSize="10sp"
                    android:fontFamily="@font/montserrat_regular"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Two-column body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:weightSum="2">

        <!-- LEFT COLUMN: Status + WiFi icon -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <!-- WiFi Status -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📶 Network Status"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="6dp" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="6dp"
                        android:paddingHorizontal="12dp"
                        android:background="?attr/colorSurfaceVariant"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/wifiEnabledLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/wifi_enabled_label"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:ellipsize="end"
                            android:maxLines="1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/wifiEnabledIndicator"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <ImageView
                            android:id="@+id/wifiEnabledIndicator"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/wifi_enabled_label"
                            android:src="@drawable/ic_circle_red"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="6dp"
                        android:paddingHorizontal="12dp"
                        android:background="?attr/colorSurfaceVariant">

                        <TextView
                            android:id="@+id/wifiConnectedLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/wifi_connected_label"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:ellipsize="end"
                            android:maxLines="1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/wifiConnectedIndicator"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <ImageView
                            android:id="@+id/wifiConnectedIndicator"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/wifi_connected_label"
                            android:src="@drawable/ic_circle_red"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WiFi icon fills remaining space -->
            <FrameLayout
                android:id="@+id/bottomWifiContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center">

                <ImageView
                    android:id="@+id/bottomWifiIcon"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:alpha="0.6"
                    android:contentDescription="@string/wifi_icon_desc" />
            </FrameLayout>
        </LinearLayout>

        <!-- RIGHT COLUMN: Server control + URL -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="6dp">

            <!-- Server Control -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/connected_to_label"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTertiary"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvSsid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAlignment="center"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="?attr/colorSecondaryContainer"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:padding="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="8dp"
                        android:elevation="2dp"
                        tools:text="Sample SSID" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnServerToggle"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="@string/start_server"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_media_play"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        android:backgroundTint="?attr/colorPrimary"
                        android:textColor="?attr/colorOnPrimary"
                        android:layout_marginBottom="6dp"
                        app:elevation="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="6dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNearbyDevices"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="@string/nearby_devices"
                            android:textSize="10sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            app:cornerRadius="8dp"
                            app:icon="@android:drawable/stat_sys_data_bluetooth"
                            app:iconSize="12dp"
                            app:iconPadding="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTheme"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="@string/change_theme"
                            android:textSize="10sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSecurity"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="🔒 Security Settings"
                        android:textSize="11sp"
                        app:cornerRadius="8dp"
                        app:strokeWidth="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Web URL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/file_explorer_web_url_label"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorTertiary"
                            android:letterSpacing="0.05"
                            android:ellipsize="end"
                            android:maxLines="1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/wifiOptions"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <ImageView
                            android:id="@+id/wifiOptions"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="4dp"
                            android:contentDescription="@string/wifi_options"
                            android:src="@drawable/ic_wrench"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/tvWebUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAlignment="center"
                        android:textSize="14sp"
                        android:background="?attr/colorSecondaryContainer"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:padding="10dp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:textIsSelectable="true"
                        android:fontFamily="monospace"
                        android:elevation="2dp"
                        tools:text="http://192.168.1.100:8080" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
