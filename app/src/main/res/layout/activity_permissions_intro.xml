<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Branded Header — matches main activity -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#0A1628">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical"
            android:background="#0A1628">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/icon"
                android:contentDescription="FileBeacon logo"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FileBeacon"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your files. Always within reach."
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_regular"
                    android:textColor="#00BFFF"
                    android:layout_marginTop="1dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Location Permission -->
            <TextView
                android:id="@+id/tvLocationExplain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/perm_location_explain"
                android:textSize="15sp"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="12dp"
                android:textAlignment="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestLocation"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/perm_location_button"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginBottom="28dp" />

            <!-- Storage / Media Permission -->
            <TextView
                android:id="@+id/tvMediaExplain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/perm_media_explain"
                android:textSize="15sp"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="12dp"
                android:textAlignment="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestMedia"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/perm_media_button"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestWriteStorage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/request_storage"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestManageStorage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/request_all_files_access"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginBottom="28dp" />

            <!-- Skip Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkipPermissions"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/skip_permissions"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:strokeWidth="2dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="?attr/colorError"
                android:textColor="?attr/colorError"
                android:layout_marginBottom="12dp" />

            <!-- Warning Text -->
            <TextView
                android:id="@+id/tvSkipWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/skip_warning_message"
                android:textSize="13sp"
                android:textColor="?attr/colorError"
                android:textAlignment="center"
                android:padding="8dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
