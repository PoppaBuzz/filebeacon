<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Legacy theme alias for backward compatibility with WiFi File Explorer -->
    <style name="Theme.FileBeacon" parent="Base.Theme.FileBeacon" />
    <style name="Theme.WiFiFileExplorer" parent="Base.Theme.FileBeacon" />
    <style name="CustomAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/md_theme_light_background</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TitleTextStyle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/BodyTextStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.MediumComponent</item>
    </style>
    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="TitleTextStyle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/md_theme_light_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">40sp</item>
    </style>
    <style name="BodyTextStyle" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/md_theme_light_secondary</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="PositiveButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/md_theme_light_secondary</item>
        <item name="rippleColor">@color/md_theme_light_secondaryContainer</item>
    </style>
    <style name="NegativeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/md_theme_light_tertiaryContainer</item>
        <item name="rippleColor">@color/md_theme_light_onTertiaryContainer</item>
    </style>
</resources>

